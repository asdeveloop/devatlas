{
  "name": "devatlas-platform",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "build": "turbo run build",
    "build:api": "pnpm --filter @devatlas/api build",
    "build:web": "pnpm --filter @devatlas/web build",
    "dev": "turbo run dev",
    "dev:api": "pnpm --filter @devatlas/api dev",
    "dev:web": "pnpm --filter @devatlas/web dev",
    "lint": "turbo run lint",
    "lint:api": "pnpm --filter @devatlas/api lint",
    "lint:web": "pnpm --filter @devatlas/web lint",
    "lint:report": "eslint . -f github",
    "test": "turbo run test",
    "test:api": "pnpm --filter @devatlas/api test",
    "test:web": "pnpm --filter @devatlas/web test",
    "typecheck": "turbo run typecheck",
    "typecheck:api": "pnpm --filter @devatlas/api typecheck",
    "typecheck:web": "pnpm --filter @devatlas/web typecheck",
    "verify:api": "pnpm --filter @devatlas/api db:check && pnpm lint:api && pnpm typecheck:api && pnpm test:api",
    "verify:web": "pnpm lint:web && pnpm typecheck:web && pnpm test:web",
    "agent:verify": "node scripts/agent-verify.mjs",
    "agent:context": "node scripts/agent-context.mjs",
    "doctor": "node scripts/doctor.mjs",
    "health": "node scripts/health.mjs",
    "health:verbose": "node scripts/health.mjs --verbose",
    "generate:api-client": "pnpm --filter @devatlas/api-client generate",
    "search:smoke": "node scripts/search-smoke.mjs",
    "deploy:staging": "node scripts/deploy/staging-release.mjs"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@eslint/js": "9.39.1",
    "@openapitools/openapi-generator-cli": "2.31.1",
    "@typescript-eslint/eslint-plugin": "8.59.0",
    "@typescript-eslint/parser": "8.59.0",
    "esbuild": "0.25.0",
    "eslint": "9.39.4",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-boundaries": "5.0.0",
    "eslint-plugin-import": "2.32.0",
    "fast-glob": "3.3.3",
    "globals": "16.5.0",
    "ignore": "7.0.5",
    "lint-staged": "16.4.0",
    "ts-error-formatter": "0.2.1",
    "ts-node": "10.9.2",
    "tsup": "8.5.1",
    "turbo": "2.9.6",
    "typescript": "5.9.3",
    "typescript-eslint": "8.59.0",
    "vite": "7.3.2",
    "vitest": "3.2.4",
    "whatwg-encoding": "3.1.1"
  },
  "packageManager": "pnpm@10.33.2",
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20.11.0 <23",
    "pnpm": ">=8"
  }
}
