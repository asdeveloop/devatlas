{
  "name": "devatlas-platform",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint:report": "eslint . -f github",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "health": "pnpm typecheck && pnpm lint && pnpm test",
    "doctor": "node scripts/doctor.mjs",
    "combine": "node scripts/combine-files.js",
    "generate:api-client": "pnpm --filter @devatlas/api-client generate"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",

    "eslint": "9.39.4",
    "@typescript-eslint/eslint-plugin": "8.0.0",
    "@typescript-eslint/parser": "8.0.0",
    "eslint-plugin-boundaries": "5.0.0",
    "eslint-plugin-import": "2.32.0",

    "typescript": "5.9.3",
    "vitest": "3.2.4",
    "vite": "7.3.2",
    "esbuild": "0.25.0",

    "@openapitools/openapi-generator-cli": "2.31.1",
    "fast-glob": "3.3.3",
    "ignore": "7.0.5",
    "lint-staged": "16.4.0",
    "ts-error-formatter": "0.2.1",
    "ts-node": "10.9.2",
    "tsup": "8.5.1",
    "turbo": "2.9.6",
    "whatwg-encoding": "3.1.1"
  },
  "packageManager": "pnpm@10.33.0",
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
