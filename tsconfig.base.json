{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],

    "module": "ESNext",
    "moduleResolution": "Bundler",

    "strict": true,
    "noImplicitOverride": true,
    "noUncheckedIndexedAccess": true,
    "noFallthroughCasesInSwitch": true,
    "noPropertyAccessFromIndexSignature": true,

    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,

    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "skipLibCheck": true,

    "verbatimModuleSyntax": true,

    "baseUrl": ".",

    "paths": {
      "@devatlas/types": ["packages/types/src"],
      "@devatlas/types/*": ["packages/types/src/*"],

      "@devatlas/ui": ["packages/ui/src"],
      "@devatlas/ui/*": ["packages/ui/src/*"],

      "@devatlas/config": ["packages/config/src"],
      "@devatlas/config/*": ["packages/config/src/*"],

      "@devatlas/utils": ["packages/utils/src"],
      "@devatlas/utils/*": ["packages/utils/src/*"],

      "@devatlas/content": ["packages/content/src"],
      "@devatlas/content/*": ["packages/content/src/*"],

      "@devatlas/api-client": ["packages/api-client/src"],
      "@devatlas/api-client/*": ["packages/api-client/src/*"]
    }
  }
}
