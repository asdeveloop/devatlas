{
  "$schema": "https://turbo.build/schema.json",

  "globalDependencies": [
    "package.json",
    "pnpm-lock.yaml",
    "tsconfig.base.json",
    "*.config.{js,mjs,ts,cjs}",
    "**/.env",
    "**/.env.*",
    "eslint.config.mjs"
  ],

  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**"],
      "cache": true
    },

    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^dev"]
    },

    "lint": {
      "outputs": [],
      "cache": true
    },

    "test": {
      "outputs": ["coverage/**"],
      "cache": true
    },

    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": [],
      "cache": true
    }
  }
}
