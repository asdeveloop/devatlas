{
  "name": "@devatlas/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsc --project tsconfig.build.json --outDir dist --rootDir src --incremental false",
    "dev": "nest start --watch",
    "lint": "eslint src --ext .ts --max-warnings=0",
    "test": "vitest run --passWithNoTests --config vitest.config.ts",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "DATABASE_URL=${DATABASE_URL:-postgresql://devatlas:devatlas@localhost:5432/devatlas?schema=public} prisma generate --schema prisma/schema.prisma",
    "prisma:validate": "DATABASE_URL=${DATABASE_URL:-postgresql://devatlas:devatlas@localhost:5432/devatlas?schema=public} prisma validate --schema prisma/schema.prisma",
    "prisma:migrate:dev": "DATABASE_URL=${DATABASE_URL:-postgresql://devatlas:devatlas@localhost:5432/devatlas?schema=public} prisma migrate dev --schema prisma/schema.prisma",
    "prisma:migrate:deploy": "DATABASE_URL=${DATABASE_URL:-postgresql://devatlas:devatlas@localhost:5432/devatlas?schema=public} prisma migrate deploy --schema prisma/schema.prisma"
  },
  "dependencies": {
    "@devatlas/types": "workspace:^",
    "@nestjs/common": "11.1.18",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "11.1.18",
    "@nestjs/platform-express": "11.1.18",
    "@prisma/client": "^6.19.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "nestjs-zod": "^5.3.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.5",
    "@nestjs/swagger": "^11.2.7",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/swagger-ui-express": "^4.1.8",
    "prisma": "^6.19.3",
    "swagger-ui-express": "^5.0.1"
  }
}
