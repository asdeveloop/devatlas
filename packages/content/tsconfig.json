{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],

    "rootDir": "src",
    "outDir": "dist",

    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,

    "noUnusedLocals": true,
    "noUnusedParameters": true,

    "composite": true
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.ts",
    "src/indexer/db-mapper.ts",
    "src/indexer/relation-indexer.ts",
    "src/pipeline.ts",
    "src/pipeline/content-pipeline.ts",
    "src/validator/**/*.ts",
    "src/types/guide.ts",
    "src/types/tool.ts"
  ]
}
